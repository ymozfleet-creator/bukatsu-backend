rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuth() { return request.auth != null; }
    function isOwner(uid) { return isAuth() && request.auth.uid == uid; }
    function sizeOK() { return request.resource.size() < 900000; }

    // 共有データ（コーチ・チーム・選手・支払い等）
    match /appdata/shared {
      allow read: if isAuth();
      allow write: if isAuth() && sizeOK();
    }
    // 個人データ（設定・トレーニングログ等）
    match /appdata/{uid} {
      allow read, write: if isOwner(uid) && sizeOK();
    }
    // チャット
    match /chats/{roomKey} {
      allow read, write: if isAuth();
      match /messages/{msgId} {
        allow read: if isAuth();
        allow create: if isAuth()
          && request.resource.data.text is string
          && request.resource.data.text.size() <= 2000;
      }
    }
    // メールアドレス検索
    match /users_by_email/{emailKey} {
      allow read, write: if isAuth();
    }
    // ユーザーアカウント
    match /users/{uid} {
      allow read: if isAuth();
      allow write: if isOwner(uid);
    }
    // デフォルト拒否
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
